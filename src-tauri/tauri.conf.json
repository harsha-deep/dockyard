{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "dockyard",
  "version": "0.5.0",
  "identifier": "com.harsha.dockyard",
  "build": {
    "beforeDevCommand": "bun run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "bun run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Dockyard",
        "width": 800,
        "height": 600
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/harsha-deep/dockyard/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEFCQTNFNjM1MTQ0OUE0MjEKUldRaHBFa1VOZWFqcTZLL0xObnNZMWVtRks0VVZ1V2QxK01SSSs1ZXpGQ3hsdllza09OdFVHZHcK"
    }
  }
}
